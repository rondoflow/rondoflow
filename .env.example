DATABASE_URL=postgresql://rondoflow:rondoflow_dev@localhost:5432/rondoflow
PORT=3001
UI_ORIGIN=http://localhost:3000

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3001

# First-admin bootstrap (invite-only). Open self-registration is disabled — an
# admin creates all accounts. On seed/startup, if RONDOFLOW_ADMIN_EMAIL is set
# and no such user exists, an admin account is created with this password.
# Rotate the password after first login; leave blank in shared environments.
RONDOFLOW_ADMIN_EMAIL=
RONDOFLOW_ADMIN_PASSWORD=
RONDOFLOW_ADMIN_NAME=Administrator

# Claude auth (required for agent execution) — provide ONE of the two:
#   ANTHROPIC_API_KEY       — a standard Anthropic API key (billed per token)
#   CLAUDE_CODE_OAUTH_TOKEN — a setup token from `claude setup-token` (uses your Claude subscription)
# If both are set, the setup token takes precedence.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Sakana AI (optional) — required only for the Sakana AI canvas node.
SAKANA_API_KEY=

# Apify (optional) — required only for the Apify Actor canvas node.
# Personal API token from https://console.apify.com/account/integrations
APIFY_TOKEN=

# Max output tokens per agent response. Raised so long results aren't cut off
# with "output was truncated due to token limits". Claude Code clamps this to
# each model's true max (Opus ~128k, Sonnet/Haiku ~64k), so the default is safe.
CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000
 
# Claude Code telemetry (optional) — forwarded to spawned Claude Code processes.
# Fill the source vars below; OTEL_* values are derived automatically when left blank.
CLAUDE_CODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_ENDPOINT=
AUTH_TOKEN=
USER_EMAIL=
OTEL_METRIC_EXPORT_INTERVAL=60000
OTEL_LOGS_EXPORT_INTERVAL=5000
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_RESOURCE_ATTRIBUTES=

# OAuth (optional — leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email node (SMTP) — powers the canvas "Email" node, which sends a workflow's
# output as an HTML email. Also configurable at runtime in Settings → credentials
# (a DB-stored value overrides these at boot). Leave SMTP_HOST blank to disable.
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE — true for port 465 (implicit TLS); false for 587 (STARTTLS).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# SMTP_FROM — sender address, e.g. "RondoFlow <noreply@example.com>"
SMTP_FROM=

# External folders (host directories agents can read/write/git over)
# EXTERNAL_FOLDERS_HOST_PATH — host path bind-mounted into the server container
#   at the container root below. Drop project folders under it (or add explicit
#   bind mounts in docker-compose.yml under /external) and they appear in the UI.
EXTERNAL_FOLDERS_HOST_PATH=./external
# EXTERNAL_FOLDERS_CONTAINER_ROOT — in-container root all registered folders must
#   resolve under. Change only if you change the mount target in docker-compose.yml.
EXTERNAL_FOLDERS_CONTAINER_ROOT=/external

RONDOFLOW_DEBUG_SPAWN=1
IS_SANDBOX=1

# Spawn timeouts — protect against a hung Claude CLI process (stalled network, an
# unanswerable permission prompt, an infinite loop). All in milliseconds.
#   RONDOFLOW_SPAWN_IDLE_TIMEOUT_MS — kill a run that streams NO event for this
#     long. Resets on every stream event, so it's safe for long-lived interactive
#     agents and only fires on a true stall. Applies to every spawn. 0 disables.
RONDOFLOW_SPAWN_IDLE_TIMEOUT_MS=300000
#   RONDOFLOW_SPAWN_MAX_MS — absolute wall-clock cap applied to every spawn
#     regardless of activity. Off (0) by default; one-shot generators set their own.
RONDOFLOW_SPAWN_MAX_MS=0

# In-flight run teardown on client disconnect (last socket + grace period).
#   RONDOFLOW_TEARDOWN_ON_DISCONNECT — when a user's last tab disconnects, tear
#     down their in-flight runs after the grace window. Set to 0 to keep runs
#     alive across disconnect (only server shutdown then tears them down).
RONDOFLOW_TEARDOWN_ON_DISCONNECT=1
#   RONDOFLOW_TEARDOWN_GRACE_MS — grace window before disconnect teardown fires.
#     A refresh / new tab / reconnect within this window cancels it.
RONDOFLOW_TEARDOWN_GRACE_MS=60000