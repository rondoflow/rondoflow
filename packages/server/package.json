    "@prisma/client": "^6.5.0",
    "@rondoflow/shared": "*",
    "better-auth": "^1.5.5",
    "croner": "^10.0.1",
    "fastify": "^5.2.0",
    "nodemailer": "^6.9.16",
    "openai": "^6.42.0",
    "socket.io": "^4.8.0",
    "zod": "^3.24.0"
  },
  "prisma": {
    "seed": "tsx --env-file=../../.env prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@vitest/coverage-v8": "^4.1.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
